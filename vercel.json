{
  "version": 2,
  "builds": [
    {
      "src": "serverless.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/app$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/serverless.ts"
    }
  ]
}
