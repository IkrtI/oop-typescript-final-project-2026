{
  "version": 2,
  "builds": [
    {
      "src": "serverless.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "frontend/**",
          "data/**",
          "node_modules/swagger-ui-dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/serverless.ts"
    }
  ]
}
